# SQLite (default, zero-setup)
DATABASE_URL=sqlite:///./fleetfit.db

# PostgreSQL (uncomment and edit to use instead)
# DATABASE_URL=postgresql://username:password@localhost:5432/fleetfit

# JWT secret - change this to a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
